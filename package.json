    "test:e2e:ui": "playwright test --ui",
    "icons": "node scripts/generate-icons.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
